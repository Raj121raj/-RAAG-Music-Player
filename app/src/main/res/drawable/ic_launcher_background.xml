<?xml version="1.0" encoding="utf-8"?>
<!--
    RAGG Cinematic Launcher Icon — Background Layer
    Deep AMOLED with centered radial purple glow
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base AMOLED layer -->
    <path
        android:fillColor="#0B0F1A"
        android:pathData="M0,0h108v108h0z" />

    <!-- Radial purple glow from center -->
    <path
        android:pathData="M0,0h108v108h0z"
        android:fillAlpha="1">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="60"
                android:type="radial">
                <item android:offset="0" android:color="#206D28D9" />
                <item android:offset="0.5" android:color="#0E8B5CF6" />
                <item android:offset="1" android:color="#000B0F1A" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
