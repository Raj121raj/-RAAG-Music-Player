<?xml version="1.0" encoding="utf-8"?>
<!--
    RAAG Cinematic Launcher Icon — Background v31 (Android 12+)
    Uses deep AMOLED with centered purple radial glow — premium feel
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- AMOLED base -->
    <path
        android:fillColor="#0B0F1A"
        android:pathData="M0,0h108v108h0z" />

    <!-- Centered radial glow — premium purple depth -->
    <path
        android:pathData="M0,0h108v108h0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="55"
                android:type="radial">
                <item android:offset="0" android:color="#286D28D9" />
                <item android:offset="0.45" android:color="#128B5CF6" />
                <item android:offset="1" android:color="#000B0F1A" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
